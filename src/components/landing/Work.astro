---
import defaultProjectImage from "@/images/projects/default.svg";
import EditableImage from "@/components/landing/EditableImage.astro";
import PortfolioMediaLink from "@/components/landing/PortfolioMediaLink.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { workItems } from "@/data/portfolio";
---

<section class="scroll-mt-32" id="work">
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-4 items-start">
      <div class="lg:col-start-2">
        <Text
          tag="p"
          variant="textSM"
          class="text-base-600 dark:text-base-300"
          data-editable="sections.work.eyebrow"
          >Trabalhos recentes
          <br />
          Sua experiência</Text
        >
      </div>
      <Text
        tag="h2"
        variant="textXL"
        class="font-semibold leading-snug text-left tracking-tighter lg:col-span-2 text-base-900 dark:text-white"
        data-editable="sections.work.title"
      >
        Trabalho
      </Text>
    </div>

    <div class="flex flex-col lg:gap-12 mt-8">
      {
        workItems.map((project) => (
          <article class="py-12 border-t border-base-200 dark:border-base-800">
            <div class="grid grid-cols-1 gap-4 lg:grid-cols-4 items-start">
              <Text
                tag="p"
                variant="textXS"
                class="text-base-600 dark:text-base-300 uppercase"
                data-editable={`work.${project.slug}.year`}
              >
                {project.year}
              </Text>
              <Text
                tag="h3"
                variant="displaySM"
                class="text-base-900 dark:text-white leading-tight font-semibold "
                data-editable={`work.${project.slug}.title`}
              >
                {project.title}
              </Text>
              <Text
                tag="p"
                variant="textSM"
                class="text-base-600 dark:text-base-300"
                data-editable={`work.${project.slug}.description`}
              >
                {project.description}
              </Text>
              <Text
                tag="p"
                variant="textXS"
                class="text-base-600 dark:text-base-300 uppercase lg:ml-auto lg:col-start-4"
                data-editable={`work.${project.slug}.category`}
              >
                {project.category}
              </Text>
            </div>
            <PortfolioMediaLink href={`/trabalho/${project.slug}`}>
              <EditableImage
                imageKey={`work.${project.slug}.image`}
                width={1420}
                height={930}
                src={defaultProjectImage}
                alt={`Imagem do trabalho ${project.title}`}
                loading="lazy"
                decoding="async"
                class="size-full aspect-4/2 object-cover object-center transition-transform duration-500 group-hover:scale-[1.02]"
              />
            </PortfolioMediaLink>
          </article>
        ))
      }
    </div>
  </Wrapper>
</section>
