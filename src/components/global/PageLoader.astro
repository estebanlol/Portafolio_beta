<div
  id="page-loader"
  class="fixed inset-0 z-50 flex flex-col bg-white dark:bg-base-950"
  aria-hidden="true"
>
  <div class="flex items-start justify-between px-6 py-6 lg:px-12">
    <span class="text-xs tracking-tight text-base-600 dark:text-base-300">lore</span>
    <span class="text-xs tracking-tight text-base-600 dark:text-base-300 uppercase"
      >Carregando</span
    >
  </div>

  <div class="flex flex-1 items-center justify-center">
    <div class="flex items-end gap-1">
      <span
        id="loader-counter"
        class="text-[clamp(4rem,18vw,12rem)] font-semibold leading-none tracking-tighter text-base-900 dark:text-white tabular-nums"
        >0</span
      >
      <span
        class="mb-[0.35em] text-[clamp(1.25rem,4vw,2.5rem)] font-semibold tracking-tighter text-base-400 dark:text-base-500"
        >%</span
      >
    </div>
  </div>

  <div class="px-6 pb-8 lg:px-12">
    <div class="h-px w-full overflow-hidden bg-base-200 dark:bg-base-800">
      <div
        id="loader-progress"
        class="h-full w-0 origin-left bg-base-900 dark:bg-white"
      ></div>
    </div>
  </div>
</div>

<script>
  import gsap from "gsap";

  const loader = document.getElementById("page-loader");
  const counter = document.getElementById("loader-counter");
  const progress = document.getElementById("loader-progress");
  const pageContent = document.getElementById("page-content");

  if (loader && counter && progress) {
    document.body.classList.add("overflow-hidden");

    if (pageContent) {
      gsap.set(pageContent, { opacity: 0 });
    }

    const counterState = { value: 0 };

    const runLoader = () => {
      gsap.to(counterState, {
        value: 100,
        duration: 2.4,
        ease: "power2.inOut",
        onUpdate: () => {
          const current = Math.round(counterState.value);
          counter.textContent = String(current);
          progress.style.width = `${current}%`;
        },
        onComplete: () => {
          const timeline = gsap.timeline({
            onStart: () => {
              window.dispatchEvent(new CustomEvent("page-loader-complete"));
            },
            onComplete: () => {
              loader.remove();
              document.body.classList.remove("overflow-hidden");
            },
          });

          timeline.to(loader, {
            yPercent: -100,
            duration: 0.9,
            ease: "power4.inOut",
          });

          if (pageContent) {
            timeline.to(
              pageContent,
              {
                opacity: 1,
                duration: 0.6,
                ease: "power2.out",
              },
              "-=0.45",
            );
          }
        },
      });
    };

    if (document.readyState === "complete") {
      runLoader();
    } else {
      window.addEventListener("load", runLoader, { once: true });
    }
  }
</script>
